{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "src/server.js" },
    { "src": "/auth/(.*)", "dest": "src/server.js" },
    { "src": "/dashboard(.*)", "dest": "/public/dashboard.html" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
